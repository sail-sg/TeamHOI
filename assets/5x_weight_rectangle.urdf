<?xml version="1.0"?>
<robot name="rect_table_200x120_inset_5x_weight">

  <!-- Rectangular tabletop: X=2.00 m, Y=1.20 m, H=0.04 m -->

<link name="tabletop">
  <inertial>
    <origin xyz="0 0 0"/>
    <mass value="288.0"/>
    <inertia
      ixx="34.632" ixy="0" ixz="0"
      iyy="96.064" iyz="0"
      izz="130.56"/>
  </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="2.00 1.20 0.04"/>
      </geometry>
      <material name="wood"><color rgba="0.6 0.4 0.2 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="2.00 1.20 0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- Leg template: 0.04 x 0.04 x 0.82 (centered) -->
  <link name="leg1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.7296"/>
      <inertia
        ixx="0.03521536" ixy="0" ixz="0"
        iyy="0.03521536" iyz="0"
        izz="0.00019456"/>
    </inertial>
    <visual><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></visual>
    <collision><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></collision>
  </link>

  <link name="leg2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.7296"/>
      <inertia
        ixx="0.03521536" ixy="0" ixz="0"
        iyy="0.03521536" iyz="0"
        izz="0.00019456"/>
    </inertial>
    <visual><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></visual>
    <collision><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></collision>
  </link>

  <link name="leg3">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.7296"/>
      <inertia
        ixx="0.03521536" ixy="0" ixz="0"
        iyy="0.03521536" iyz="0"
        izz="0.00019456"/>
    </inertial>
    <visual><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></visual>
    <collision><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></collision>
  </link>

  <link name="leg4">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.7296"/>
      <inertia
        ixx="0.03521536" ixy="0" ixz="0"
        iyy="0.03521536" iyz="0"
        izz="0.00019456"/>
    </inertial>
    <visual><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></visual>
    <collision><origin xyz="0 0 0"/><geometry><box size="0.04 0.04 0.82"/></geometry></collision>
  </link>

  <!-- Fixed joints: inset legs -->
  <!-- half-dimensions: hx=1.00, hy=0.60; inset=0.12 => (±0.88, ±0.48) -->
  <!-- z = -(0.02 + 0.41) = -0.43 -->
  <joint name="table_leg1" type="fixed">
    <parent link="tabletop"/>
    <child  link="leg1"/>
    <origin xyz=" 0.88  0.48 -0.43" rpy="0 0 0"/>
  </joint>

  <joint name="table_leg2" type="fixed">
    <parent link="tabletop"/>
    <child  link="leg2"/>
    <origin xyz="-0.88  0.48 -0.43" rpy="0 0 0"/>
  </joint>

  <joint name="table_leg3" type="fixed">
    <parent link="tabletop"/>
    <child  link="leg3"/>
    <origin xyz="-0.88 -0.48 -0.43" rpy="0 0 0"/>
  </joint>

  <joint name="table_leg4" type="fixed">
    <parent link="tabletop"/>
    <child  link="leg4"/>
    <origin xyz=" 0.88 -0.48 -0.43" rpy="0 0 0"/>
  </joint>

</robot>
